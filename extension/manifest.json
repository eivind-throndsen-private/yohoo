{
    "manifest_version": 3,
    "name": "Yohoo Helper",
    "version": "0.2.0",
    "description": "Improves dropped-link titles in Yohoo and opens trusted local file links.",
    "permissions": [
        "tabs"
    ],
    "host_permissions": [
        "http://*/*",
        "https://*/*",
        "file:///*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "https://eivind-throndsen-private.github.io/yohoo/*",
                "http://localhost/*",
                "http://127.0.0.1/*",
                "file:///*"
            ],
            "js": [
                "content-script.js"
            ],
            "run_at": "document_start"
        }
    ]
}
